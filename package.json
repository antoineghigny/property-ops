{
  "name": "property-ops",
  "version": "0.1.0",
  "description": "Agentic operating system for residential property analysis, financing, and bank packages",
  "type": "module",
  "scripts": {
    "init-user": "node scripts/init-user-files.mjs",
    "doctor": "node scripts/doctor.mjs",
    "profile-status": "node scripts/profile-status.mjs --json",
    "verify:cases": "node scripts/verify-cases.mjs",
    "verify:packs": "node scripts/verify-packs.mjs",
    "verify:bank-packages": "node scripts/verify-bank-packages.mjs",
    "verify": "npm run verify:packs && npm run verify:cases && npm run verify:bank-packages",
    "test": "node --test tests/*.test.mjs",
    "screen": "node scripts/cli.mjs screen",
    "ingest": "node scripts/cli.mjs ingest",
    "resolve-identity": "node scripts/cli.mjs resolve-identity",
    "analyze": "node scripts/cli.mjs analyze",
    "score": "node scripts/cli.mjs score",
    "comps": "node scripts/cli.mjs comps",
    "finance": "node scripts/cli.mjs finance",
    "collect-docs": "node scripts/cli.mjs collect-docs",
    "bank-package": "node scripts/cli.mjs bank-package",
    "visit": "node scripts/cli.mjs visit",
    "compare": "node scripts/cli.mjs compare",
    "tracker": "node scripts/cli.mjs tracker",
    "batch": "node scripts/cli.mjs batch",
    "negotiate": "node scripts/cli.mjs negotiate",
    "refresh": "node scripts/cli.mjs refresh"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "cheerio": "^1.1.2",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.1",
    "playwright": "^1.58.1",
    "zod": "^4.1.12"
  }
}
